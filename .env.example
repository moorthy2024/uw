# -----------------------------
# App & API Configuration
# -----------------------------
NEXT_PUBLIC_APP_NAME=QBE Commercial Property AI UW Agent

# REQUIRED: Backend API base URL used by src/lib/api/http-client.ts
# Update per environment (dev/test/prod), e.g. https://api-dev.company.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_TIMEOUT_MS=15000
NEXT_PUBLIC_API_RETRY_COUNT=2
NEXT_PUBLIC_ENABLE_CHAT_STREAMING=false
# local = browser localStorage, server = call /api/chats stubs.
NEXT_PUBLIC_CHAT_PERSISTENCE_MODE=local

# -----------------------------
# NextAuth Configuration
# -----------------------------
# REQUIRED: Public app URL for NextAuth callback construction.
NEXTAUTH_URL=http://localhost:3000

# REQUIRED: Secret used to sign NextAuth JWT/session cookies.
NEXTAUTH_SECRET=

# Azure AD / Entra ID OAuth client details.
# REQUIRED: Set these in secure deployment secret stores.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_MANAGER_GROUP_ID=
AZURE_AD_UNDERWRITER_GROUP_ID=

# Optional backend audience/scope used during token refresh or API access checks.
# Example: api://<backend-app-id>/.default
AZURE_AD_SCOPE=
